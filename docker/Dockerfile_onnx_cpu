FROM python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    ffmpeg \
    libsndfile1 \
    && rm -rf /var/lib/apt/lists/*

COPY onnx_requirements.txt dev_requirements.txt  test_requirements.txt calibration_requirements.txt ./

RUN python -m pip install --upgrade pip && \
    python -m pip install --no-cache-dir -r test_requirements.txt

COPY SDP/ ./SDP/
COPY configs/ ./configs/
COPY tests/ ./tests/
COPY scripts/ci/ ./scripts/ci/
COPY run_phase_three.py ./

CMD ["bash", "scripts/ci/run_onnx_tests.sh"]
